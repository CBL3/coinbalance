{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coinbalance.local/schemas/telemetry-event.schema.json",
  "title": "CoinBalanceTelemetryEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_type",
    "timestamp",
    "trace_id",
    "tenant_id",
    "actor",
    "source",
    "risk_level"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "workflow_started",
        "workflow_completed",
        "workflow_failed",
        "agent_invoked",
        "model_selected",
        "tool_called",
        "policy_evaluated",
        "human_approval_requested",
        "human_feedback_recorded",
        "fallback_triggered",
        "incident_detected",
        "state_snapshot_created",
        "state_replayed"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "trace_id": {
      "type": "string",
      "minLength": 8
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "workflow_id": {
      "type": "string"
    },
    "agent_id": {
      "type": "string"
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "id"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "human",
            "agent",
            "system"
          ]
        },
        "id": {
          "type": "string"
        },
        "role": {
          "type": "string"
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "component"
      ],
      "properties": {
        "component": {
          "type": "string"
        },
        "environment": {
          "type": "string",
          "enum": [
            "local",
            "dev",
            "staging",
            "production",
            "on_prem"
          ]
        }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "routing_reason": {
          "type": "string"
        },
        "prompt_version": {
          "type": "string"
        },
        "input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "output_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "estimated_cost": {
          "type": "number",
          "minimum": 0
        },
        "latency_ms": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "policy_version": {
          "type": "string"
        },
        "decision": {
          "type": "string",
          "enum": [
            "allow",
            "deny",
            "require_approval",
            "quarantine"
          ]
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "input_ref": {
      "type": "string",
      "description": "Hash or storage reference. Do not store sensitive raw input here."
    },
    "output_ref": {
      "type": "string",
      "description": "Hash or storage reference. Do not store sensitive raw output here."
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "user_feedback": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "properties": {
        "rating": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "accepted": {
          "type": "boolean"
        },
        "comment_ref": {
          "type": "string"
        }
      }
    },
    "state_checksum": {
      "type": "string"
    }
  }
}
